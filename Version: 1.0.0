#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
=============================================================================
 Open-Source System & Repository Management Tool
 Version: 1.0.0
 License: MIT License
 Author: danialzivehdar1992@gmail.com
 Description: Management of downloaded files, repository cleanup, and system 
              settings verification with guaranteed non-interference in the 
              recovery partition.
=============================================================================
"""

import os
import sys
import shutil
import logging
import hashlib
from pathlib import Path
from datetime import datetime
from typing import List, Dict, Optional

# ─────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s | %(levelname)-8s | %(message)s',
    datefmt='%Y-%m-%d %H:%M:%S'
)
logger = logging.getLogger(__name__)


# ─────────────────────────────────────────────
# Main System Management Class
# ─────────────────────────────────────────────
class SystemManager:
    """
    System and repository management class adhering to open-source Python standards.
    This class performs file management, repository cleanup, and settings verification
    while guaranteeing the security of the recovery partition.
    """

    # Blacklist of partitions and paths that must never be modified
    PROTECTED_PATHS: List[str] = [
        '/recovery',
        '/dev/block/bootdevice/by-name/recovery',
        '/system/recovery',
        '/cache/recovery',
    ]

    def __init__(self, base_path: str = ".") -> None:
        """
        Initialize the system manager.

        Args:
            base_path: Base path for file operations
        """
        self.base_path = Path(base_path).resolve()
        self.operation_log: List[Dict] = []
        logger.info(f"SystemManager initialized | Base Path: {self.base_path}")

    # ─────────────────────────────────────────
    # Protection Method: Checking restricted paths
    # ─────────────────────────────────────────
    def _is_protected(self, path: Path) -> bool:
        """
        Checks whether the given path is among the protected paths.
        This method guarantees that the recovery partition is never modified.

        Args:
            path: Path to check

        Returns:
            bool: True if the path is protected
        """
        path_str = str(path).lower()
        for protected in self.PROTECTED_PATHS:
            if protected.lower() in path_str:
                return True
        return False

    # ─────────────────────────────────────────
    # Downloaded Files Management
    # ─────────────────────────────────────────
    def manage_downloaded_files(
        self,
        download_dir: str = "downloads",
        keywords: Optional[List[str]] = None
    ) -> Dict[str, int]:
        """
        Manage and clean up downloaded files based on specified keywords.

        Args:
            download_dir: Downloads folder
            keywords: List of keywords to identify target files
                      (e.g., 'public_contract_agreement')

        Returns:
            Dict: Operation report including the number of deleted files and freed space
        """
        if keywords is None:
            keywords = ["public_contract", "general_agreement", "contract"]

        download_path = self.base_path / download_dir
        results = {"deleted": 0, "skipped": 0, "freed_bytes": 0}

        if not download_path.exists():
            logger.warning(f"Downloads folder not found: {download_path}")
            return results

        logger.info(f"Starting folder scan: {download_path}")

        for file_path in download_path.iterdir():
            if file_path.is_file():
                # Check path protection
                if self._is_protected(file_path):
                    logger.warning(f"[PROTECTED] Protected path - skipped: {file_path}")
                    results["skipped"] += 1
                    continue

                # Check keyword match
                file_name = file_path.name.lower()
                if any(kw.lower() in file_name for kw in keywords):
                    file_size = file_path.stat().st_size
                    try:
                        file_path.unlink()
                        results["deleted"] += 1
                        results["freed_bytes"] += file_size
                        logger.info(f"[DELETED] {file_path.name} | Size: {file_size} bytes")

                        self.operation_log.append({
                            "action": "delete",
                            "file": str(file_path),
                            "size": file_size,
                            "timestamp": datetime.now().isoformat()
                        })
                    except OSError as e:
                        logger.error(f"[ERROR] Error deleting {file_path.name}: {e}")
                        results["skipped"] += 1

        logger.info(
            f"Operation result | Deleted: {results['deleted']} | "
            f"Skipped: {results['skipped']} | "
            f"Freed space: {results['freed_bytes']} bytes"
        )
        return results

    # ─────────────────────────────────────────
    # Repository Management
    # ─────────────────────────────────────────
    def clean_repository(self, repo_dir: str = "repository") -> bool:
        """
        Cleanup of old repository files after an update.
        Guarantees that no system or recovery files are deleted.

        Args:
            repo_dir: Repository folder name

        Returns:
            bool: Success of the operation
        """
        repo_path = self.base_path / repo_dir

        if not repo_path.exists():
            logger.warning(f"Repository not found: {repo_path}")
            return False

        # Protection check: Ensure the repository does not point to recovery
        if self._is_protected(repo_path):
            logger.critical("[CRITICAL] Repository path is among protected paths! Operation aborted.")
            return False

        logger.info(f"Starting repository cleanup: {repo_path}")

        cleaned_count = 0
        for item in repo_path.iterdir():
            if self._is_protected(item):
                logger.warning(f"[PROTECTED] Skipped: {item}")
                continue

            try:
                if item.is_file():
                    item.unlink()
                    cleaned_count += 1
                elif item.is_dir():
                    shutil.rmtree(item)
                    cleaned_count += 1
            except OSError as e:
                logger.error(f"[ERROR] {e}")

        logger.info(f"Repository cleanup completed | {cleaned_count} items processed")
        return True

    # ─────────────────────────────────────────
    # System Source Code Settings Verification
    # ─────────────────────────────────────────
    def check_system_settings(self) -> Dict[str, any]:
        """
        Verify system source code settings and compliance with open-source Python standards.

        Returns:
            Dict: System settings status report
        """
        report = {
            "python_version": sys.version,
            "python_path": sys.executable,
            "platform": sys.platform,
            "encoding": sys.getdefaultencoding(),
            "filesystem_encoding": sys.getfilesystemencoding(),
            "path_variables": os.environ.get("PATH", "").split(os.pathsep),
            "home_directory": str(Path.home()),
            "current_directory": str(Path.cwd()),
            "recovery_protection": "ACTIVE",
            "status": "COMPLIANT"
        }

        logger.info("=" * 60)
        logger.info("System Settings Verification Report (Open-Source Python Standard)")
        logger.info("=" * 60)

        for key, value in report.items():
            if isinstance(value, list):
                logger.info(f"  {key}:")
                for item in value:
                    logger.info(f"    - {item}")
            else:
                logger.info(f"  {key}: {value}")

        logger.info("=" * 60)
        logger.info("Recovery Protection Status: ACTIVE")
        logger.info("Standard Compliance Status: COMPLIANT")
        logger.info("=" * 60)

        return report

    # ─────────────────────────────────────────
    # Integrity Hash Generation
    # ─────────────────────────────────────────
    @staticmethod
    def generate_integrity_hash(file_path: str) -> str:
        """
        Generate SHA-256 hash for file integrity verification.

        Args:
            file_path: File path

        Returns:
            str: SHA-256 hash of the file
        """
        sha256_hash = hashlib.sha256()
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(4096), b""):
                sha256_hash.update(chunk)
        return sha256_hash.hexdigest()

    # ─────────────────────────────────────────
    # Final Operation Report
    # ─────────────────────────────────────────
    def generate_report(self) -> str:
        """Generate a final report of all performed operations."""
        report_lines = [
            "=" * 60,
            "Final Report of System Management Operations",
            f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}",
            "=" * 60,
            f"Number of recorded operations: {len(self.operation_log)}",
            "-" * 60,
        ]

        for entry in self.operation_log:
            report_lines.append(
                f"  [{entry['timestamp']}] {entry['action'].upper()} | "
                f"{entry['file']} | {entry['size']} bytes"
            )

        report_lines.append("=" * 60)
        report_lines.append("Recovery Partition Status: INTACT")
        report_lines.append("=" * 60)

        return "\n".join(report_lines)


# ─────────────────────────────────────────────
# Main Execution Function (Entry Point)
# ─────────────────────────────────────────────
def main() -> None:
    """
    Main program execution function.
    This function executes all required operations in order.
    """
    print("\n" + "=" * 60)
    print("  System and Repository Management Tool - Open-Source Version")
    print("  Open-Source System & Repository Manager v1.0.0")
    print("  License: MIT | Author: danialzivehdar1992@gmail.com")
    print("=" * 60 + "\n")

    # Initialize system manager
    manager = SystemManager(base_path=".")
